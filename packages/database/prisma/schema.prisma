// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ShapeType {
  BOX
  ELLIPSE
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /* relation to Room model */
  rooms     Room[]
}

model Room {
  id           String   @id @default(uuid())
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /* foreign key + relation to User model (admin of the room) */
  adminId  String
  admin    User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  /* relation to Shape model */
  shapes    Shape[]

  @@index([adminId])
}

model Shape {
  id        String   @id @default(uuid())
  type      ShapeType? @default(BOX)

  x         Float
  y         Float
  width     Float?
  height    Float?
  radius    Float?

  points    Json?     // for freehand / pencil / line
  style     Json?     // strokeColor, fillColor, strokeWidth, etc.

  // relation to Room model
  roomId    String
  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([roomId])
}